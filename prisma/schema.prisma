// Qift platform schema.
//
// Datasource is SQLite (see datasource block below). A few SQLite-specific
// constraints to keep in mind when extending this file:
//   - Prisma `enum` declarations are not used; allowed values for status-like
//     columns are documented inline as comments next to each field.
//   - All `@unique`/`@@unique` constraints are case-sensitive. Username and
//     email are normalised to lowercase at the application layer.
//   - Foreign-key cascade rules behave the same as Postgres in Prisma's
//     emitted SQL, so `onDelete: Cascade | SetNull | Restrict` are honoured.
//
// Naming convention: camelCase fields in Prisma (Prisma maps these to the
// same names in the SQLite tables — no `@@map` is used elsewhere in this
// file, so we keep that consistency here too).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  fullName        String?
  phone           String    @unique
  email           String?   @unique
  qiftUsername    String    @unique
  passwordHash    String?
  defaultAddress  String?
  // Verification timestamps for the canonical contact channels.
  // Set when a fresh OTP successfully verifies the channel; cleared
  // when the user changes the channel value (the new value needs a
  // fresh proof of ownership).
  //
  //   phoneVerifiedAt — set at /auth/register (every account is
  //                      OTP-bound at creation); the existing-rows
  //                      backfill in the migration sets this to
  //                      `createdAt` for accounts that pre-date the
  //                      column.
  //   emailVerifiedAt — null until an email-OTP flow lands. The
  //                      /social-accounts page surfaces a Verified /
  //                      Unverified chip from this column.
  phoneVerifiedAt DateTime?
  emailVerifiedAt DateTime?
  // "user" | "store" | "admin"
  //   user   — default. Regular gifting account.
  //   store  — owns at least one Store row; sees /store-dashboard.
  //   admin  — internal Qift staff. Sees /admin and can promote
  //            other accounts. Promotion happens via PATCH
  //            /admin/users/:id/role and is persisted here. Only
  //            another admin can grant the role; the very first
  //            admin is set manually in the DB (UPDATE "User" SET
  //            role='admin' WHERE id='…').
  role            String    @default("user")

  // -- Profile content (added in Step 2) --
  // Short biography rendered on /u/[username]. App-level cap of 280 chars
  // (mirrors the frontend constraint). Null until the user fills it in.
  bio       String?
  // Public avatar URL (object storage). Until set, the UI falls back to
  // a gradient + initials avatar derived from `fullName` / `qiftUsername`.
  avatarUrl String?

  // -- Privacy flags (added in Step 2) --
  // "public" | "private". When private, /u/[username] returns the limited
  // profile view (avatar + name + handle + private-account message).
  profileVisibility   String  @default("public")
  // Per-section privacy. The API enforces these — the schema only stores
  // them. When false, the corresponding count or list is omitted from
  // /users/@/:username responses entirely (the client sees an absent field
  // rather than a "0" or a forbidden flag).
  showGiftsReceived   Boolean @default(true)
  showGiftsSent       Boolean @default(true)
  showFollowers       Boolean @default(true)
  showFollowing       Boolean @default(true)
  // Phone-discoverability switch. When false this account is hidden
  // from `/users/search?type=phone` even if the searcher knows the
  // exact number. Phone is the most privacy-sensitive contact channel
  // — a user may want to be findable by username while staying
  // unreachable by raw phone-number lookups (e.g. account is in a
  // contact list of someone they no longer interact with). Defaults
  // to true so existing demo accounts keep their current behaviour.
  allowPhoneDiscovery Boolean @default(true)
  // Email-discoverability switch — narrower invariant than phone.
  // When false, /users/search?type=email returns nothing even on
  // exact match. Email is a permanent identifier reused across
  // services; defaulting it on would convert every legitimate
  // sender-confirmation flow into an enumeration surface
  // (gmail.com, hotmail.com, corporate domains). DEFAULT-DENY:
  // the user must explicitly opt in from /settings privacy. The
  // QA audit added this column after finding email search was
  // substring-matched without any opt-in gate.
  allowEmailDiscovery Boolean @default(false)

  // -- Wishlist preferences (added for MVP private testing) --
  // All optional; designed to seed AI gift recommendations later. We
  // store sizes as free-form strings (e.g. "M", "44 EU", "Size 8")
  // because clothing/shoe/ring sizing varies by region and brand —
  // forcing a numeric type would lose information. Comma-separated
  // taste fields (favorite_*) are simple strings for now; the future
  // recommender can tokenize on commas without a schema migration.
  preferredClothingSize String?
  preferredShoeSize     String?
  preferredRingSize     String?
  preferredPerfume      String?
  favoriteColors        String?
  favoriteCategories    String?
  favoriteBrands        String?
  allergies             String?
  // Sender-side default: when true, friends sending a gift can flip
  // the "surprise" toggle and the receiver sees the mystery card
  // (per the existing isSurprise flow). When false, the receiver has
  // declared they don't want surprises — the /send page can warn
  // senders. UI gate only; backend doesn't currently enforce it on
  // gift create.
  acceptsSurpriseGifts  Boolean @default(true)
  // Free-form note from the owner to gift senders. Capped on
  // write at 280 chars (server enforces). Opt-in shareable via
  // preferencesVisibility key 'giftNote'. Examples:
  //   "أفضل العطور الهادئة"
  //   "I prefer practical gifts"
  //   "my size varies by brand"
  // Plain text only — no HTML, no markdown rendering, no URLs
  // auto-linked on the public surface.
  giftNote              String?
  // Per-field publicity flags for the preferences above. JSON for
  // policy flexibility — adding a new preference field doesn't need
  // a schema migration. Default null = ALL private (owner-only). The
  // shape is a small `{ <field>: boolean }` object; recognized keys:
  //   clothingSize | shoeSize | ringSize | fragrance | colors |
  //   categories | brands | allergies | surprises | giftNote
  // The public-profile endpoint reads this to decide which
  // preference fields to project into the response. Per-field
  // privacy is opt-in: each flag defaults to false until the owner
  // explicitly flips it.
  preferencesVisibility Json?

  // -- Account state --
  // Read by /users/me. The frontend renders the red "address required"
  // banner when this is true.
  isSuspended Boolean   @default(false)
  createdAt   DateTime  @default(now())
  // Soft-delete sentinel. Required because Gift FKs use Cascade (see Gift
  // relations below): hard-deleting a User would also delete every gift
  // they were involved in. Soft-deleting (setting this column) preserves
  // history; the API filters live users via `where deletedAt is null`.
  deletedAt   DateTime?
  // Permanent-deletion sentinel.
  //
  // Distinct from `deletedAt` — purge is the GDPR-style "right to be
  // forgotten with regulatory preservation" pattern:
  //   - PII columns on this row are anonymized: `phone` and
  //     `qiftUsername` are rewritten to deterministic sentinels
  //     (`__purged__:<id>`) so the @unique constraints don't block
  //     re-registration with the original values. `email` and every
  //     other PII column are nulled.
  //   - Identity-PII tables tied to this user (Address,
  //     SocialAccount, PushSubscription, Wish, Post, Follow, Block,
  //     Notification, NotificationPreferences, OccasionReminder,
  //     GiftPostAppreciation, GiftAttempt) are hard-deleted in the
  //     same transaction.
  //   - Transactional / financial / audit tables (Gift, Order,
  //     GiftSession, MerchantOrder, RefundRequest, GiftPost, Report,
  //     Invite, AuditLog) are PRESERVED with the FK still pointing
  //     at this tombstone — regulatory retention (ZATCA financial,
  //     trust+safety record) trumps PII removal.
  //
  // `deletedAt` is also set at purge time, so every existing
  // soft-delete filter (auth.service.login, /users/search, public
  // profile, admin user list default) excludes purged rows for free.
  // `purgedAt` distinguishes "soft-delete (reversible)" from
  // "purge (irreversible)" — the admin UI uses this to render a
  // permanent "Purged" chip and refuse the restore action.
  //
  // Only super_admin can write this column (gated by the
  // `user.purge` ops-permission; trust_safety has user.suspend but
  // NOT user.purge — too irreversible for that role).
  purgedAt    DateTime?

  addresses             Address[]
  socialAccounts        SocialAccount[]
  sentGifts             Gift[]                 @relation("SenderGifts")
  receivedGifts         Gift[]                 @relation("ReceiverGifts")
  orders                Order[]
  notifications         Notification[]
  // Phase 7.1 — one preferences row per user, lazily created on
  // first read. Drives the orchestrator's quiet-hours + opt-out
  // decisions.
  notificationPreferences NotificationPreferences?
  ownedStores           Store[]
  pushSubscriptions     PushSubscription[]
  // Follows (added in Step 2). `following` = rows where this user IS the
  // follower; `followers` = rows where this user IS being followed.
  following             Follow[]               @relation("OutgoingFollows")
  followers             Follow[]               @relation("IncomingFollows")
  // Wishlist items. Per-Wish visibility ("public" | "private") gates which
  // ones appear on /u/:username; the owner sees them all on /profile.
  wishes                Wish[]
  // Gift posts this user owns (sender's "sent" post or receiver's
  // "received" post). The Gift Wall on /profile + /u/:username is a
  // simple `WHERE ownerUserId = :userId` query. See model GiftPost.
  ownedGiftPosts        GiftPost[]             @relation("OwnedGiftPosts")
  // 👍 appreciations this user has placed on others' gift posts.
  // See model GiftPostAppreciation.
  giftPostAppreciations GiftPostAppreciation[]
  // Failed gift-send attempts where this user was the sender or the
  // receiver. We notify the sender once the receiver finally sets a
  // default address. See model GiftAttempt below.
  attemptedGifts        GiftAttempt[]          @relation("SenderAttempts")
  pendingAttempts       GiftAttempt[]          @relation("ReceiverAttempts")
  // Granular ops-role assignments (layered on top of the coarse
  // `role` field for admin users). See model OpsRoleAssignment.
  opsRoles              OpsRoleAssignment[]
  // Block relations. `outgoingBlocks` = rows where this user IS the
  // blocker; `incomingBlocks` = rows where this user IS being blocked.
  // Search + public-profile + send-gift surfaces filter both directions
  // out so blocked users can't interact in either direction.
  outgoingBlocks        Block[]                @relation("Blocker")
  incomingBlocks        Block[]                @relation("Blocked")
  // Reports filed by this user against another. We don't expose the
  // reverse relation publicly — reports are admin-only.
  filedReports          Report[]               @relation("Reporter")
  // Profile posts (added in Step 3). Each post has one media item
  // (photo or short video) stored on R2. Visible on /profile (owner)
  // and on the user's public profile when profile visibility allows.
  posts                 Post[]

  // Phase 6 — Occasions infrastructure. Two distinct relations:
  //
  //   ownedOccasions    : occasions the user owns (their own birthday,
  //                       their wedding anniversary, custom events).
  //   relatedOccasions  : occasions someone ELSE created that point at
  //                       this user as the related party (e.g. "Sarah's
  //                       birthday" — a remembrance row owned by the
  //                       remembering user but pointing at Sarah).
  //   occasionReminders : reminder rows the user owns. Reminders are
  //                       owned by the recipient of the reminder, not
  //                       the occasion's owner — a remembering user
  //                       can have their own reminder cadence on a
  //                       relatedOccasion.
  //
  // The actual reminder FIRING is gated to Phase 7 (notification
  // budget infrastructure). Phase 6.1 ships the data layer only.
  ownedOccasions        Occasion[]             @relation("OwnedOccasions")
  relatedOccasions      Occasion[]             @relation("RelatedOccasions")
  occasionReminders     OccasionReminder[]

  // Invitation MVP — manual-share.
  // `mintedInvites`  : invites this user created in /search no-match.
  // `consumedInvite` : the invite this user joined via, if any
  //                    (legacy users + admin-created have null).
  // Single-cardinality on `consumedInvite` is enforced at the Invite
  // table level (one Invite has one consumedByUserId); we don't
  // unique-constrain it here because re-using a link across users
  // is gated by the invite's `status` transition, not by a DB key.
  mintedInvites         Invite[]               @relation("InviteCreator")
  consumedInvites       Invite[]               @relation("InviteConsumer")
}

model Address {
  id               String  @id @default(cuid())
  userId           String
  label            String?
  country          String
  region           String?
  city             String
  governorate      String?
  district         String
  street           String?
  buildingNumber   String?
  unitNumber       String?
  postalCode       String?
  additionalNumber String?
  shortAddress     String?
  deliveryPhone    String?
  lat              Float?
  lng              Float?
  details          String
  isDefault        Boolean @default(false)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  gifts Gift[] @relation("GiftDeliveryAddress")

  @@index([userId])
}

model SocialAccount {
  id                String   @id @default(cuid())
  userId            String
  platform          String
  handle            String
  url               String?
  verified          Boolean  @default(false)
  // Tri-state ownership signal:
  //   'unverified'    — manual link (current default for /social-accounts).
  //   'verified'      — OTP / SMS / email OTP proved control (for the
  //                     channels where that's possible).
  //   'oauth_verified'— a future OAuth integration confirmed the
  //                     account ID via the platform's API.
  // We keep `verified: Boolean` for backward-compat — it should be `true`
  // whenever verificationLevel != 'unverified'. Reads should prefer
  // `verificationLevel` for the chip; writes should set both fields.
  verificationLevel String   @default("unverified")
  isPrimary         Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, handle])
  @@index([userId])
}

model Gift {
  id          String  @id @default(cuid())
  senderId    String
  receiverId  String
  productName String
  storeName   String
  // Optional FK to the Store row that owns this order. Legacy gifts
  // (and gifts shipped from sample/demo stores) leave this null and
  // never appear in the per-store dashboard. New API-fed orders set it
  // so the dashboard can filter by ownership.
  storeId     String?
  productId   String?
  // Phase 6 — optional FK tagging a gift to an occasion the sender
  // is acknowledging ("Sarah's birthday"). Sender-side metadata
  // ONLY: receivers never see the sender's occasion tag on a gift
  // they received (prevents tone-pushing abuse). On occasion soft-
  // delete the FK stays — the tag value preserves through deletion
  // because gifting history shouldn't lose meaning when an
  // occasion row gets cleaned up. SetNull on hard delete only.
  occasionId  String?
  // Buyer's gift message — rendered in the receiver's gift detail AFTER
  // delivery. The store NEVER sees this field; the message-reveal gate
  // strips it from any non-sender, non-delivered viewer.
  messageText String?
  // Optional media attachment (image or video URL). Same privacy rules
  // as messageText — masked for receiver until delivery, never exposed
  // to the store. mediaType discriminates the renderer on the receiver
  // side ("image" → <img>, "video" → <video>).
  mediaUrl    String?
  mediaType   String?
  // Final v3 pipeline:
  //   pending_address      → waiting on the receiver
  //   address_confirmed    → receiver picked an address
  //   default_address_used → 24h elapsed; we used their default
  //   preparing            → store accepted the order
  //   shipped              → courier handed off
  //   delivered            → arrived
  //   cancelled            → either party (or admin) cancelled
  status      String  @default("pending_address")
  isAnonymous Boolean @default(false)
  // Sender-controlled "surprise mode". When true, the receiver is told a
  // gift is on the way but `productName` / `storeName` are masked from
  // their view until status === 'delivered'. Default `false` means
  // visible-immediately (current pre-flag behaviour) so existing rows
  // and existing callers don't change semantics. The store + sender
  // ALWAYS see real values; the mask is purely a receiver-side reveal.
  isSurprise  Boolean @default(false)
  addressId   String?

  // Tracking timestamps. Each one is written exactly once (the first time
  // the gift enters that phase) so the timeline can render the full
  // history regardless of later transitions.
  confirmedAt    DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  trackingNumber String?
  carrier        String?

  createdAt DateTime @default(now())

  // Week 2 — idempotency on POST /gifts. Optional Idempotency-Key
  // (from the request header) plus a SHA-256 of the canonicalised
  // request body. Both NULL on every existing row + on every gift
  // created without the header — current behaviour is preserved
  // for callers that opt out.
  //
  //   idempotencyKey         — the client-supplied opaque string
  //                            (max 255 chars enforced at service
  //                            layer). Compound unique with
  //                            senderId so each sender has an
  //                            independent key namespace.
  //   idempotencyRequestHash — hex SHA-256 of the canonicalised
  //                            request body. Re-submitting the
  //                            same key with a DIFFERENT body
  //                            returns 409 idempotency_key_reused
  //                            instead of silently shadowing the
  //                            first request.
  //
  // PostgreSQL allows multiple NULLs in a unique-constrained
  // column, so legacy gifts (key=NULL) are not constrained — the
  // unique applies only when key is non-NULL.
  idempotencyKey         String?
  idempotencyRequestHash String?

  sender   User       @relation("SenderGifts", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User       @relation("ReceiverGifts", fields: [receiverId], references: [id], onDelete: Cascade)
  address  Address?   @relation("GiftDeliveryAddress", fields: [addressId], references: [id], onDelete: SetNull)
  store    Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  product  Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  occasion Occasion?  @relation("OccasionGifts", fields: [occasionId], references: [id], onDelete: SetNull)
  order    Order?
  shipment Shipment?
  // One GiftPost per (gift, owner) — both sender and receiver can
  // independently publish their own perspective on the same Gift.
  // The relation is therefore one-to-many on this side; the
  // composite uniqueness on GiftPost(giftId, ownerUserId) still
  // caps the total at TWO posts per gift.
  posts    GiftPost[]

  @@index([senderId])
  @@index([receiverId])
  // Per-store dashboard query: find every order for stores X belongs to.
  @@index([storeId, status])
  // Used by the 24h auto-default sweep (find pending gifts past their TTL).
  @@index([status, createdAt])
  // Week 2 idempotency — the compound is the dedup primitive. The
  // unique constraint is what makes the concurrent-retry case
  // race-safe: two simultaneous POSTs with the same key both pass
  // the pre-check, both attempt create, the second receives a
  // Prisma P2002 which the service catches + refetches.
  @@unique([senderId, idempotencyKey])
}

// Failed gift-send attempts. Created when a sender tries to send a gift
// but the receiver has no default delivery address. We block the gift
// (no Gift row is written) and instead persist enough context here to:
//   1. Notify the receiver that someone tried to send them something.
//   2. Notify the sender once the receiver fixes their address — this
//      is the resolve-on-default-set hook in AddressesService.
//
// We deliberately do NOT store messageText / mediaUrl. Those are private
// content the receiver hasn't earned the right to see, and they're
// irrelevant to the "you can now retry" notification. productName /
// storeName are safe — sender chose to share them and they'll be re-
// entered when the sender retries the send anyway.
//
// `resolvedAt` is set when the sender has been pinged for this row (or
// when the row was deliberately dropped — e.g. account deletion). The
// resolve-on-default-set query filters on `resolvedAt IS NULL` so a row
// is only ever notified once.
model GiftAttempt {
  id               String    @id @default(cuid())
  senderId         String
  receiverId       String
  // Snapshot of the username at attempt time so a future receiver
  // rename doesn't break the audit trail.
  receiverUsername String
  productName      String?
  storeName        String?
  createdAt        DateTime  @default(now())
  notifiedAt       DateTime?
  resolvedAt       DateTime?

  sender   User @relation("SenderAttempts", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceiverAttempts", fields: [receiverId], references: [id], onDelete: Cascade)

  // Resolve-on-default-set lookup: WHERE receiverId = ? AND resolvedAt IS NULL.
  @@index([receiverId, resolvedAt])
  @@index([senderId])
}

// First-class store catalog. Every Store has exactly one owner (the User
// who registered it). Integration metadata lives here too so we can
// migrate stores between manual / API / Shopify / etc. without touching
// product rows.
//
// MERCHANT ONBOARDING v2
// What started as a thin (name, city, category) row grew into a full
// merchant-application record. The new fields below capture the
// information real businesses provide during onboarding: legal entity
// + tax IDs, contact PoC, branding, social presence, and structured
// delivery coverage. All new columns are NULLABLE so legacy stores
// (pre-onboarding-v2) continue to work without migration data backfill.
model Store {
  id       String @id @default(cuid())
  name     String
  ownerId  String
  city     String
  category String

  // ── Business / legal identity ─────────────────────────────────
  // All optional — pre-v2 stores have these as null and the admin
  // dashboard renders "—" in their place.
  legalEntityName              String?
  // ISO-3166 alpha-2 country code (SA / KW / AE / QA / BH / OM /
  // OTHER). Drives the per-country business-document expectations
  // (CR for Saudi, MOCI license for Kuwait, etc.) on the frontend.
  countryOfRegistration        String?
  // Country-specific business identifier. Saudi: 10-digit CR. Kuwait:
  // MOCI license. UAE: trade license. Bahrain: CR. Qatar: CR. Oman:
  // CR. Free-text on the wire — frontend validates against the
  // active country's expected format.
  commercialRegistrationNumber String?
  vatNumber                    String?

  // ── Contact PoC ───────────────────────────────────────────────
  contactPerson String?
  contactPhone  String?
  contactEmail  String?

  // ── Branding & social ─────────────────────────────────────────
  logoUrl         String?
  coverImageUrl   String?
  websiteUrl      String?
  instagramHandle String?
  tiktokHandle    String?
  snapchatHandle  String?

  // ── Delivery coverage ─────────────────────────────────────────
  // Authoritative coverage definition. JSON array of
  //   { city: string; districts?: string[]; note?: string }
  // entries (mirrors lib/deliveryZones.ts on the frontend). Null /
  // empty array → fall back to the legacy single-`city` field above
  // (the existing canDeliverTo matcher already does this). Snapshot
  // is forwarded to Order.deliveryZones at create time so a mid-
  // flight zone change can't invalidate pending gifts.
  deliveryZones Json?

  // "none" | "api" | "shopify" | "woocommerce" | "custom"
  integrationType   String @default("none")
  // "disconnected" | "connected" | "error"
  integrationStatus String @default("disconnected")

  // ── Merchant plan ─────────────────────────────────────────────
  // Tiered feature gating. Stable string union so adding tiers
  // doesn't need a Prisma enum migration:
  //   starter     — default for new merchants. In-Qift storefront,
  //                 products, gifting, basic analytics, coverage,
  //                 order management.
  //   pro         — adds API/Shopify/Woo integrations, advanced
  //                 analytics, campaigns/promotions, better
  //                 placement, automation.
  //   enterprise  — custom integrations, SLA, advanced APIs,
  //                 branded gifting, advanced reporting, future
  //                 split-payment capabilities.
  // Plan changes are admin-assigned today (PATCH /admin/stores/:id/plan).
  // Self-serve upgrades + subscription billing are intentionally
  // out of scope — see project_merchant_platform_direction memory.
  // The capability map (apps/api/src/stores/merchant-plans.ts)
  // is the only thing that should consume this field; never
  // hardcode a plan check inline.
  plan String @default("starter")

  // Marketplace surfacing. When true, the store appears in the
  // "Featured" rail on /stores and gets boosted placement. Admin-
  // toggled today (PATCH /admin/stores/:id/featured); future
  // editorial / earned-placement rules can layer on top without
  // a schema change.
  featured Boolean @default(false)

  // ── Approval lifecycle ────────────────────────────────────────
  // Onboarding-v2 expanded states (string union, additive — every
  // pre-v2 row stays valid):
  //   draft              — merchant started the form but hasn't submitted.
  //   submitted          — application submitted; awaiting admin pickup.
  //   pending_review     — admin is actively reviewing.
  //   changes_requested  — admin sent back for fixes; rejectionReason
  //                        carries the operator's note.
  //   approved           — live; appears in /stores and merchant
  //                        fulfilment queue.
  //   rejected           — admin denied; rejectionReason carries why.
  //   suspended          — was approved, later disabled by admin.
  //   pending            — legacy alias for "submitted" (pre-v2 rows).
  // Existing rows backfilled to "approved" so the migration is non-
  // destructive (every store created before this column existed was
  // implicitly live).
  status String @default("pending")

  // Operator-supplied note when the admin rejects or requests
  // changes. Surfaced on the merchant's pending-approval screen so
  // they know what to fix. Cleared when a fresh submission moves
  // back to `submitted`/`pending_review`.
  rejectionReason String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  // FK to User.id of the admin who reviewed. Audit trail; not used
  // for auth (the admin guard runs against the JWT viewer at
  // request time).
  reviewedBy      String?

  // Used to verify webhook signatures from the upstream platform. Null
  // for manual stores; generated when an integration is connected.
  webhookSecret String?
  createdAt     DateTime @default(now())

  // ── Storefront theme (Phase 5) ────────────────────────────────
  // Currently selected presentation layer. Stable string union
  // (NOT a Prisma enum) so adding a new theme is a one-line
  // change in the `themes.ts` manifest + a new component file —
  // no schema migration required. Plan gating is enforced by
  // StoreService on every set + every render via the live plan
  // capability check (capabilitiesFor() / planHas() from
  // merchant-plans.ts). A downgrade leaves this value alone but
  // the server-side dispatcher falls back to `classic` until the
  // plan is restored.
  themeSlug   String @default("classic")
  // Bounded per-store overrides. Recognized keys (validated
  // server-side; unknown keys silently dropped):
  //   accentColor     — hex (sanitized to known palette)
  //   bannerImageUrl  — R2 URL pointer
  //   heroHeadline    — max 80 chars
  //   heroSubhead     — max 160 chars
  //   themeSpecific.<slug>.* — per-theme sub-config (each theme
  //     declares its own validator)
  // See `project_storefront_architecture.md` Section 2.4 / 3.2.
  themeConfig Json?

  // ── Merchant metrics visibility (Phase 5) ─────────────────────
  // Per-metric publicity flags. JSON column following the same
  // pattern as User.preferencesVisibility — opt-in basis, each key
  // defaults to false (owner-only). Recognized keys:
  //   wishlistSaves      — "N people saved this"
  //   purchaseCount      — "N bought"
  //   giftedCount        — "N gifted via Qift"
  //   popularityScore    — "trending" badge
  //   ratingsCount       — review count
  //   stockCount         — "only N left"
  //   soldCount          — "M sold this month"
  //   trendingIndicator  — "trending now"
  // The storefront primitives (<MetricChip>) render nothing for
  // missing keys. The API projection drops hidden keys server-
  // side so themes never see raw values they shouldn't render.
  // Default null = ALL HIDDEN (treated as every flag = false).
  metricsVisibility Json?

  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products  Product[]
  gifts     Gift[]
  documents StoreDocument[]
  wishes    Wish[]
  // Qift Business eligibility layer (B1). One profile per store;
  // NO row = the store never applied. Consumer approval and
  // business approval are independent decisions by design.
  businessProfile StoreBusinessProfile?

  @@index([ownerId])
}

// Storefront theme registry. Display metadata + plan gating for
// the available themes. The actual theme COMPONENTS live in the
// frontend codebase under `components/storefront/themes/<slug>/`;
// this table carries only the metadata the dashboard picker needs
// (preview thumbnail, localized name/description, plan gate, on/off).
//
// V1 seed rows: 'classic' (starter+), 'gallery' (pro+),
// 'editorial' (enterprise). Adding a new theme = one INSERT here
// + a new component file + an entry in the frontend `themes.ts`
// manifest. No schema change required.
//
// Plan gating is enforced server-side by StoreService — the
// dashboard picker uses `minPlan` to grey out ineligible options,
// but the authoritative check happens on every `setTheme` + every
// public storefront render.
model StoreTheme {
  slug           String   @id
  // Localized via translation key `themes.<slug>.name`. The `name`
  // column stores the canonical English name as a fallback.
  name           String
  // 'starter' | 'pro' | 'enterprise'. Plan capability gating is
  // the source of truth — minPlan is a display hint for the
  // picker. The matching capability ('theme_gallery' /
  // 'theme_editorial') is what the service actually checks.
  minPlan        String
  // R2 URL pointer to a static preview image (PNG/WebP). Live-
  // rendered previews are deferred — see
  // `project_storefront_architecture.md` Section 9.
  previewUrl     String
  // Translation key for the picker description. Null on themes
  // that ship without a description (only the name shows).
  descriptionKey String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

// Per-store onboarding documents (CR scan, VAT certificate,
// authorized-signatory ID, etc.). Files are uploaded to R2 via the
// existing media pipeline; this table stores the pointer + the
// document type so the admin review screen can render a structured
// list. The actual file content lives in R2 and is served through
// the same authenticated path the rest of the app uses.
//
// PRIVACY: documents are never returned on the public /stores
// listing. Read access is gated to the store owner + admins; the
// admin review endpoint is the canonical surface.
model StoreDocument {
  id          String   @id @default(cuid())
  storeId     String
  // Stable type identifier. Frontend maps it to a localised label
  // depending on the store's countryOfRegistration:
  //   commercial_registration  — CR scan
  //   vat_certificate          — VAT/tax registration cert
  //   business_license         — country-specific license (MOCI in
  //                              KW, DED in AE, etc.)
  //   owner_id                 — authorized signatory ID
  //   other                    — free-form supporting document
  type        String
  fileUrl     String
  fileName    String?
  // Optional MIME so the admin UI can pick the right preview
  // (image vs PDF). Set when the upload pipeline knows it; null
  // for legacy / external uploads.
  contentType String?
  uploadedAt  DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// Catalog row. `sourceType` discriminates manually-created products from
// products synced via an upstream integration. The (storeId,
// externalProductId) unique index is what makes the sync idempotent —
// re-syncing the same external row updates the same Product instead of
// creating a duplicate.
model Product {
  id                String    @id @default(cuid())
  storeId           String
  name              String
  price             Float
  // Legacy single-image field. Kept as a DENORMALIZED PRIMARY:
  // every Product write that supplies a `ProductImage` gallery
  // also writes `imageUrls[0]` here so older consumers that read
  // only `imageUrl` keep rendering through the migration window.
  // Phase 2.5a continues to support direct writes too (URL-paste
  // fallback in the legacy ProductModal). Phase 2.5d will drop
  // this column once every consumer has switched to the
  // `images` relation.
  imageUrl          String?
  category          String
  isFastDelivery    Boolean   @default(false)
  // "manual" | "api"
  sourceType        String    @default("manual")
  externalProductId String?
  // "in_stock" | "out_of_stock"
  stockStatus       String    @default("in_stock")
  isAvailable       Boolean   @default(true)
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())

  // Phase 2.5a — optional product video. The merchant attaches a
  // short product video; the storefront renderer will surface it
  // in a future slice (gated by NEXT_PUBLIC_PRODUCT_VIDEO_ENABLED).
  // Closed beta: backend accepts writes but no playback UI ships
  // yet. videoType discriminates the renderer so the client
  // doesn't have to MIME-sniff the URL.
  //
  //   videoUrl   — public R2 URL (or external URL for the legacy
  //                URL-paste path, same as imageUrl).
  //   videoType  — 'mp4' | 'webm' | 'mov' (the same MIMEs the
  //                Gift media endpoint accepts). Null when
  //                videoUrl is null.
  videoUrl          String?
  videoType         String?

  // Denormalized counter: distinct users who have this product on
  // their wishlist. Updated transactionally by WishesService on
  // upsert / delete. Uniqueness is guaranteed by the
  // @@unique([userId, productId]) on Wish — this counter and
  // SELECT COUNT(DISTINCT userId) WHERE productId = ? should
  // always match.
  //
  // Privacy: surfacing "N people want this" on the public
  // storefront is GATED by the per-store `metricsVisibility`
  // dict (wishlistSaves key). The projection helper
  // `projectStorefrontMetrics` drops the value before the wire
  // when the merchant hasn't opted in. The count itself never
  // exposes WHO wishlisted.
  wishlistedByCount Int @default(0)

  // Denormalized counter: gifts created against this product
  // (excluding cancelled). Incremented atomically by
  // GiftsService.create() when the gift carries a productId.
  // Backfilled from existing Gift rows in the 20260519 migration.
  //
  // Privacy: gated by the per-store `metricsVisibility` dict
  // (giftedCount key) before the wire. Never exposes WHO gifted.
  giftedByCount Int @default(0)

  // Timestamp of the most recent activity that qualifies this
  // product as "trending". Set by WishesService when a heart
  // crosses the heart-velocity threshold and by GiftsService on
  // gift create. The projection treats the product as trending
  // when `trendingAt > NOW() - TRENDING_WINDOW`.
  //
  // Privacy: gated by `metricsVisibility.trendingIndicator`.
  // The wire never carries the raw timestamp — only the resolved
  // boolean. Indexed for the descending-from-NOW range scan.
  trendingAt DateTime?

  store  Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  gifts  Gift[]
  wishes Wish[]
  // Product media gallery (added in Phase 4 — GiftPost completion).
  // `Product.imageUrl` stays as the cached "primary image" snapshot
  // for fast wishlist/storefront reads; `images` is the authoritative
  // ordered gallery source consumed by the GiftPost viewer and the
  // future storefront product modal. No binary copy anywhere — URL
  // pointers only, per `project_product_media_single_source`.
  images ProductImage[]

  // Upstream platforms use their own ids; pinning uniqueness per-store
  // means the same Shopify product id can exist across two stores
  // without colliding.
  @@unique([storeId, externalProductId])
  @@index([storeId])
  @@index([trendingAt])
}

// Ordered product media gallery. One row per image; `displayOrder`
// drives presentation. The composite unique on (productId,
// displayOrder) prevents two rows claiming the same slot; the
// service-side writer keeps consecutive ordering (0, 1, 2, ...).
//
// Storage: URL pointers only — never binary copies. Same R2/CDN
// public domain as the legacy `Product.imageUrl`. The first row
// (displayOrder = 0) MUST stay in sync with `Product.imageUrl` so
// existing wishlist / storefront / GiftPost-tile surfaces (which
// read the cached snapshot) keep rendering correctly.
//
// Backfill: the 20260517 migration seeds one row per Product with
// a non-null imageUrl. Older Products without an imageUrl simply
// have an empty gallery.
model ProductImage {
  id           String   @id @default(cuid())
  productId    String
  url          String
  // 0-based ordinal. The first image is the primary.
  displayOrder Int      @default(0)
  // Phase 2.5a — optional per-image metadata (width, height,
  // mime, alt text, blurhash, etc.). Sparse: missing entries
  // are fine; the storefront falls back to a default aspect
  // ratio + lazy intrinsic detection. The Phase 2.5a upload
  // endpoint doesn't populate this yet (server-side dimension
  // extraction is deferred until storefront gallery rendering
  // actually needs it in Phase 2.5c) — the column exists as
  // forward-compat shape so callers can begin writing it
  // without a second migration.
  imageMeta    Json?
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, displayOrder])
  @@index([productId])
}

model Order {
  id               String   @id @default(cuid())
  userId           String
  giftId           String?  @unique
  receiverUsername String
  productName      String
  storeName        String
  // Optional FK to the catalog product / store. Persisted on Order so
  // the value survives between create and payment-confirm time, when
  // the Gift gets created and inherits them.
  productId        String?
  storeId          String?
  productPrice     Float
  serviceFee       Float
  deliveryFee      Float
  totalAmount      Float
  currency         String
  country          String
  paymentProvider  String
  message          String?
  // Optional media attachment carried from /send → /checkout → POST
  // /orders. Persisted on Order so the value survives between create
  // and payment-confirm time, when the Gift gets created and inherits
  // them. Same privacy rules as Gift.mediaUrl / mediaType — these are
  // never exposed to the store; the receiver-side reveal gate strips
  // them until status === 'delivered'.
  mediaUrl         String?
  mediaType        String?
  // Sender's "surprise mode" flag. Carried through the order so the
  // payment-confirmed Gift inherits it. Default false matches the
  // Gift schema default.
  isSurprise       Boolean  @default(false)
  isAnonymous      Boolean  @default(false)
  // Optional Phase 6.4 gifting-context tag. The sender may attach
  // an occasion when sending — typically the recipient's upcoming
  // birthday or a milestone — so the eventual Gift row inherits
  // the link via PaymentsService → GiftsService.create. SetNull on
  // the underlying Occasion soft-delete so a paid order with a
  // tagged occasion isn't blocked from progressing if the occasion
  // is later removed from the owner's list.
  occasionId       String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gift    Gift?    @relation(fields: [giftId], references: [id], onDelete: SetNull)
  payment Payment?

  @@index([userId])
}

// Shipment record. Created by the merchant when they hand the
// package off to a courier. One per Gift; the giftId FK is unique
// so re-shipping (e.g. failed delivery, second attempt) updates
// the same row instead of creating duplicates. Status mirrors a
// generic courier lifecycle so we don't need a custom enum per
// provider.
//
// `provider` is a stable string code (smsa, aramex, dhl, spl,
// manual, other). The frontend resolves it into a display name
// + tracking-URL template — keeping that mapping out of the DB
// lets us add couriers without a migration. `trackingUrl` is the
// finished URL we surface to senders/recipients (provider URL
// template + tracking number); we persist it so partial-row
// rebuilds don't break the deep-link.
//
// PRIVACY: shipment data flows to the buyer + receiver + merchant.
// Tracking events do NOT include any address detail beyond what
// the merchant entered — never the receiver's full address.
model Shipment {
  id             String   @id @default(cuid())
  giftId         String   @unique
  // Stable provider code. Resolves to a display name + tracking
  // URL template on the frontend.
  provider       String
  trackingNumber String?
  trackingUrl    String?
  // "registered" | "in_transit" | "out_for_delivery" |
  // "delivered" | "exception" | "cancelled"
  // Authoritative shipment status. Independent from Gift.status —
  // the Gift status remains the user-facing flow ("preparing /
  // shipped / delivered") while Shipment.status carries finer
  // courier-side state.
  status         String   @default("registered")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  gift   Gift            @relation(fields: [giftId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]
}

// Tracking timeline event. Append-only — the merchant adds rows
// as the package moves; future API integrations will pipe
// provider webhooks into the same table. Each event carries the
// status it represents (so we can rebuild the timeline without
// joining back to Shipment) plus an operator note.
model ShipmentEvent {
  id         String   @id @default(cuid())
  shipmentId String
  status     String
  note       String?
  // When the event happened in the real world. Distinct from
  // `createdAt` (when we recorded it) so a courier delay between
  // the event and us learning about it doesn't distort the
  // timeline.
  occurredAt DateTime
  createdAt  DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  // Timeline render = events for one shipment in occurredAt order.
  @@index([shipmentId, occurredAt])
}

// ── Gift-centric social posts (foundation only) ───────────────
//
// Qift's social layer is gift-centric and privacy-first by
// design. A GiftPost is the optional, opt-in publication of a
// Gift to the platform's social surfaces (explore feed, public
// profile gift wall, marketplace social proof). The Gift always
// exists when it happens; the GiftPost only exists when the
// sender / receiver chose to share it. Counters for `giftsSent`
// + `giftsReceived` are derived from Gift rows directly — they
// do NOT depend on the existence of a GiftPost row.
//
// PHILOSOPHY (do not violate when extending this schema — see
// the memory entries `project_gift_centric_social.md`,
// `project_privacy_first_posts.md`,
// `project_self_purchase_separation.md`,
// `feedback_no_generic_social.md`):
//   1. POSTS ARE GIFT-ANCHORED. There is no path to create a
//      GiftPost without a backing Gift row. Generic
//      "upload to feed" surfaces are out of scope.
//   2. IDENTITY MASKED BY DEFAULT. `revealSender` and
//      `revealRecipient` both default to false. Even on
//      `visibility = 'public'` posts the sender + receiver are
//      anonymized unless they explicitly opt in. The post is
//      about the product + the gifting moment, not the
//      relationship.
//   3. PRODUCT-LINKED. The viewer-facing payload should pull
//      productName / storeName / images via the Gift's
//      product + store joins. When the linked Product or
//      Store is deleted, we set `deactivatedAt` on the post
//      (cascade behavior on Gift.storeId / productId is
//      SetNull today, which leaves the post orphaned — the
//      app layer detects this and treats the post as
//      deactivated). Future: a Prisma middleware / database
//      trigger sets deactivatedAt in the same transaction.
//   4. VISIBILITY AND IDENTITY DISCLOSURE ARE ORTHOGONAL.
//      A `private` post stays private regardless of reveal
//      flags. A `public` post can still be identity-masked.
//      The two settings combine in the visibility helper.
//
// SELF-PURCHASE (future):
//   When self-purchase ships as a first-class feature, a
//   separate `SelfPurchase` model (or `Gift.kind` discriminator)
//   gets its own `SelfPurchasePost` analogue. Do NOT loosen the
//   existing self-send guards on Gift to fold self-purchase
//   here.
model GiftPost {
  id                String    @id @default(cuid())
  // No `@unique` on giftId anymore — see the composite uniqueness
  // below. Both the sender AND the receiver can each independently
  // publish their own GiftPost on the same Gift; ownerUserId
  // discriminates between them.
  giftId            String
  // Owner of the post — for V1 always equals Gift.senderId OR
  // Gift.receiverId, depending on which side opted to publish.
  // Stored explicitly (rather than re-derived from Gift each
  // time) so the Gift Wall on a user's profile is a simple
  // `WHERE ownerUserId = :userId` query.
  ownerUserId       String
  // 'sent' | 'received' | 'self' — see `project_gift_post_dedup`
  // memory. V1 ships with the column populated; dedup itself is
  // future work.
  direction         String
  // Null when the GiftPost row exists but has not been published.
  publishedAt       DateTime?
  // 'private' | 'public'. V1 ships these two only;
  // 'followers' / 'mutual' tiers land alongside the richer
  // profile-privacy work.
  visibility        String    @default("private")
  // Opt-in identity reveal. Both default to false — V1 has no UI
  // to flip these; defaults to identity-masked posts forever.
  revealSender      Boolean   @default(false)
  revealRecipient   Boolean   @default(false)
  // Short, opaque, non-enumerable token for /p/<publicSlug>
  // share URLs (see `project_gift_post_sharing` memory).
  // Generated at first publish; reused across publish/unpublish
  // cycles so a shared link doesn't 404 when the user
  // re-publishes after a moment of doubt.
  publicSlug        String?   @unique
  // Denormalized 👍 count. Updated transactionally by the
  // appreciation toggle alongside GiftPostAppreciation row
  // writes. Aggregate-only — never identity-attributed on
  // public surfaces (see `project_interaction_philosophy`).
  appreciationCount Int       @default(0)
  // Set when the linked Product or Store is deleted / unpublished.
  // The feed query filters on `deactivatedAt IS NULL`; the post
  // detail UI renders a "no longer available" placeholder when
  // someone deep-links into a deactivated post.
  deactivatedAt     DateTime?
  // Operator-supplied reason for deactivation.
  deactivatedReason String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  gift          Gift                   @relation(fields: [giftId], references: [id], onDelete: Cascade)
  owner         User                   @relation("OwnedGiftPosts", fields: [ownerUserId], references: [id], onDelete: Cascade)
  appreciations GiftPostAppreciation[]

  // One GiftPost per (gift, owner). Sender + receiver can each
  // independently publish their own perspective on the same Gift —
  // identity stays masked via buildGiftPostView either way. The
  // older single-column unique on giftId was retired in the
  // 20260517 migration.
  @@unique([giftId, ownerUserId])
  // Profile Gift Wall query: `WHERE ownerUserId = :userId
  // AND publishedAt IS NOT NULL AND deactivatedAt IS NULL`,
  // ordered by publishedAt DESC.
  @@index([ownerUserId, publishedAt])
  // Future public feed query.
  @@index([visibility, publishedAt])
  @@index([deactivatedAt])
}

// Per-user appreciation on a GiftPost. Composite-unique so each
// user can only appreciate a post once (no spam-tapping the
// counter). Counter writes happen transactionally with row
// creates/deletes — same pattern as Wish + Product.wishlistedByCount.
//
// Privacy: aggregate-only on public surfaces. The list of
// appreciators is NOT exposed to third parties — only the post
// owner (and admins) can see it. This is the "no leaderboards,
// no vanity rosters" rule from `feedback_no_generic_social`.
model GiftPostAppreciation {
  id         String   @id @default(cuid())
  giftPostId String
  userId     String
  createdAt  DateTime @default(now())

  giftPost GiftPost @relation(fields: [giftPostId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([giftPostId, userId])
  @@index([userId])
}

// ── RBAC foundation ──────────────────────────────────────────
//
// Internal operations role-based access control. The legacy
// User.role is the coarse three-state discriminator that drives
// home routing + dashboard visibility (user / store / admin).
// This table layers granular ops roles on top, ONLY for users
// who also have `role = 'admin'`.
//
// Stable string union for the role code so adding a new role
// doesn't need a Prisma enum migration:
//   super_admin       — root; all permissions.
//   operations_manager — day-to-day platform operations.
//   finance           — payouts, settlements, ledger viewing.
//   merchant_review   — onboarding application review.
//   support           — read-mostly customer / merchant support.
//   trust_safety      — moderation, reports, account holds.
//   fulfillment_ops   — shipment / coverage triage.
//   analytics_viewer  — read-only access to platform analytics.
//
// (userId, role) is unique — one assignment per role per user;
// granting twice updates the existing row's grantedBy / grantedAt
// via upsert. No "expires_at" today — revocation is explicit.
//
// The capability map (apps/api/src/ops-roles/ops-roles.ts) is
// the only thing that should consume this table; never hardcode
// role-name checks at call sites.
model OpsRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  role      String
  grantedAt DateTime @default(now())
  // User.id of the admin who granted the role. Audit trail; not
  // used for auth.
  grantedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

// ── Finance operations foundation ────────────────────────────
//
// Append-only ledger of payout-relevant events per Store. NOT a
// general accounting GL — this is the operational settlement
// substrate that future payout flows will write to. Today the
// /store/payouts endpoint derives totals from Order rows;
// once real settlement lands, the totals will be summed from
// this table instead and Order becomes the immutable source.
//
// Event types (stable strings — no Prisma enum migration):
//   accrued    — order delivered; the merchant earned the
//                payable amount. (Counts toward `pending`.)
//   held       — operations placed funds on hold pending
//                investigation. (Subtracts from `pending`.)
//   released   — hold lifted; funds returned to `pending`.
//   paid       — settlement gateway transferred funds out.
//                (Subtracts from `pending`, adds to `paid`.)
//   reversed   — refund / chargeback. (Subtracts from
//                `accrued` retroactively.)
//   adjustment — operator correction with a reason note.
//
// Amounts are signed in the local currency. Audit columns
// recordedBy (User.id of the operator) and reason carry the
// explainability future audits will need.
//
// Today: no endpoints write to this table. The schema lands so
// future ops + accounting features have a stable home; the
// /store/payouts mock keeps deriving from Order.
model PayoutEvent {
  id         String   @id @default(cuid())
  storeId    String
  // Optional FK to a specific gift/order this event is tied to.
  // Null for store-level adjustments (e.g. credit, fee waiver).
  giftId     String?
  // accrued | held | released | paid | reversed | adjustment
  type       String
  // Signed amount in `currency` units (e.g. SAR). Positive for
  // funds owed to merchant; negative for deductions.
  amount     Float
  currency   String
  // Operator note — required for `adjustment` events, optional
  // for the rest.
  reason     String?
  // User.id of the operator who recorded the event. Required so
  // every row has an audit trail.
  recordedBy String
  occurredAt DateTime
  createdAt  DateTime @default(now())

  // Per-store ledger reads: filter by storeId, order by
  // occurredAt. Per-gift drilldown uses (giftId).
  @@index([storeId, occurredAt])
  @@index([giftId])
}

model Otp {
  id         String    @id @default(cuid())
  // The phone (E.164) or email this code was sent to. Indexed; not unique
  // because the same target can have multiple codes over time.
  target     String
  // SECURITY: in production this should store an Argon2id/bcrypt HASH of
  // the code, not the plaintext. The verify endpoint compares the user-
  // supplied code against the hash. Field name is preserved (rather than
  // renamed to `codeHash`) to avoid breaking existing rows / NestJS code;
  // the migration to hashed-at-rest is an app-layer rollout.
  code       String
  // "registration" | "login" | "password_reset" | "phone_change"
  // Frontend currently only uses "registration" via /otp/send + /otp/verify.
  type       String
  expiresAt  DateTime
  // -- Audit / safety fields (added in Step 2) --
  // Set on successful verify. Once non-null, the code MUST be rejected on
  // any subsequent verify attempt — one-time-code semantics.
  consumedAt DateTime?
  // Counts wrong-code attempts against this row. The verify endpoint
  // increments on mismatch and locks the row when it crosses a threshold
  // (e.g. 5). Default 0 keeps backfill trivial.
  attempts   Int       @default(0)
  // Captured at /otp/send time for abuse detection / per-IP throttling.
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([target])
  // The verify endpoint asks "the most recent un-consumed code for this
  // target + type"; this composite covers it.
  @@index([target, type, createdAt])
}

// Browser Web Push subscription. One row per user-device pair, identified
// by the push service `endpoint` URL. The endpoint is unique per row so
// repeated `subscribe` calls from the same device upsert in place rather
// than accumulating dead rows. p256dh + auth are the encryption keys
// returned by the browser when a PushSubscription is minted.
//
// On a 404/410 from the push service (subscription expired/invalidated)
// the row is deleted automatically — the PushService handles cleanup.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  // User-agent string captured at subscribe-time. Purely informational —
  // helps the user recognise their own devices in a future settings UI.
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// In-app notifications. One row per delivered notification per user; we
// don't dedupe so users can see "you got 3 gifts today" as 3 entries.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  // Free-form discriminator (e.g. "gift.received", "gift.confirm_address",
  // "gift.ready_for_delivery", "gift.delivered"). Lets the UI render an
  // icon per category without baking the text into the backend.
  type      String
  title     String
  body      String?
  // App-relative path the bell/list should navigate to. Null = no action.
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Phase 7.1 — Notification Orchestrator columns.
  //
  // category    — one of the values in NotificationCategory
  //               (notification-categories.ts). Drives budget +
  //               quiet-hours + opt-out behaviour. Null on legacy
  //               rows written before Phase 7.1.
  // priority    — 'critical' | 'high' | 'normal' | 'low'. Derived
  //               from the category at trigger time; persisted so
  //               telemetry + future ordering work has a stable
  //               read column.
  // pushDeliveredAt — set when a real-time push was actually sent.
  //               Null means either:
  //                 (a) the row was queued for digest (alert
  //                     channels deferred to the next batch)
  //                 (b) the user opted out of push for this
  //                     category
  //                 (c) push provider failed
  //               The future digest worker reads
  //                 `pushDeliveredAt IS NULL AND createdAt > windowStart`
  //               to bundle deferred notifications.
  category        String?
  priority        String?
  pushDeliveredAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  // Phase 7.1 — budget engine reads (userId, category, createdAt)
  // when counting "did this user already hit their daily / weekly
  // cap for category X". Composite index keeps the count cheap
  // even on a hot bell.
  @@index([userId, category, createdAt])
  // Phase 7.1 — digest worker reads (userId, pushDeliveredAt) to
  // pull queued notifications. Sparse index — most rows have
  // pushDeliveredAt set; the worker scans the small "still
  // pending" tail.
  @@index([userId, pushDeliveredAt])
}

// Phase 7.1 — per-user notification preferences.
//
// One row per user, lazily created on first read (defaults are
// safe so missing rows are equivalent to "no overrides"). Drives
// the Orchestrator's quiet-hours + per-category opt-out decisions.
//
// Quiet hours are stored as HH:MM strings in a named IANA timezone
// so the user-side meaning is stable across server moves. The
// service layer composes (start, end, tz) → "is now inside the
// quiet window?". Crossing midnight is supported (e.g. 22:00 →
// 08:00 means "from 10pm tonight to 8am tomorrow").
//
// categoryOptOuts is a JSON dict keyed by NotificationCategory.
// Default-allow: a missing key = opted in. Mandatory categories
// (security / OTP / legal) are bypassed regardless of the dict.
model NotificationPreferences {
  userId             String   @id
  // "HH:MM" 24-hour local time. Null on both ends = no quiet hours
  // configured. The pair must be both set or both null; the service
  // rejects half-configured states at write time.
  quietHoursStart    String?
  quietHoursEnd      String?
  // IANA timezone name. Defaults to Asia/Riyadh (Qift's primary
  // region) so users who haven't set anything still get sensible
  // local-time behaviour. The future Phase 8 internationalization
  // pass can default per-country.
  quietHoursTimezone String   @default("Asia/Riyadh")
  // Per-category opt-out dict. Shape: { [categoryId]: boolean }.
  // true = opted OUT. Missing key = opted in (default-allow).
  // The Orchestrator filters this through MANDATORY_CATEGORIES so
  // security / OTP / legal cannot be silenced.
  categoryOptOuts    Json     @default("{}")
  // Master digest toggle.
  //
  // When TRUE (default): the digest worker bundles the user's
  // queued (pushDeliveredAt=null) rows into a calm summary push
  // on their digestFrequency cadence.
  //
  // When FALSE: the digest worker does NOT send a summary push
  // for this user. Their queued rows are stamped delivered so
  // the inbox count reconciles, but no fanout fires — the user
  // discovers the rows when they open the bell themselves.
  //
  // Note: this flag controls the SUMMARY behaviour only. It does
  // not bypass quiet hours or budget caps in the orchestrator —
  // those gates still queue individual rows for digest. The flag
  // is the "I don't want a digest push at all" preference, not a
  // "skip the queueing logic" preference. The two preferences
  // happen to be a useful pair: a user who wants ZERO push
  // notifications can set quiet hours to 00:00→00:00 (always
  // quiet) and digestEnabled=false (no summary push either).
  digestEnabled      Boolean  @default(true)
  // "daily" | "weekly". The future digest worker batches non-
  // critical notifications into this cadence.
  digestFrequency    String   @default("daily")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String   @id @default(cuid())
  orderId           String   @unique
  provider          String
  providerPaymentId String?
  amount            Float
  currency          String
  status            String   @default("pending")
  createdAt         DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// Wishlist item. One row = one thing the user wants. Visibility is
// per-row (not per-user) so a user can have a mix of public and private
// wishes; the public profile endpoint filters to visibility = 'public'.
//
// `store` is a free-form string (mirrors the frontend Wish type — there's
// no FK to the catalog yet, since wishes can refer to things outside the
// connected stores). When wishes get linked to real Product rows later,
// add an optional productId here next to `store`.
// Wishlist item. The Wishlist is Qift's "❤️ destination" — every
// product the user has expressed interest in. The schema supports
// both legacy free-text wishes (the original shape — `title` +
// optional `store` string) AND product-linked entries (a real
// FK to Product, with denormalized snapshot fields for resilience
// when the Product is later edited or deactivated).
//
// PRODUCT-LINKED MIGRATION (additive)
//   - productId + storeId are new FKs.
//   - imageUrl / price / currency / productName / storeName are
//     denormalized snapshots taken at heart-time so the wishlist
//     keeps rendering a real card even if the underlying Product
//     or Store is later updated or deactivated.
//   - title remains required for legacy compatibility — when
//     productId is set, the writer mirrors productName into title
//     so existing /wishes/me consumers keep working.
//   - One wishlist row per (userId, productId) when productId is
//     non-null. Postgres NULL semantics make `@@unique([userId,
//     productId])` skip rows where productId IS NULL, which is
//     exactly what we want for legacy free-text rows.
//
// PRIVACY
//   - The visibility field stays per-row ('public' | 'private');
//     orthogonal to the user's profile visibility tier.
//   - Aggregate counts ("N people want this") are stored on the
//     Product row (wishlistedByCount) — distinct-user count
//     guaranteed by the unique constraint.
model Wish {
  id     String  @id @default(cuid())
  userId String
  // Legacy free-text fields. Required at insert time even for
  // product-linked rows (productName mirrors into title for
  // backwards compat).
  title  String
  store  String?

  // Product link (new). Null on legacy rows.
  productId String?
  storeId   String?

  // Denormalized snapshot — kept stable when the product is later
  // edited so the wishlist card doesn't visually break. Refreshed
  // on each heart-tap upsert.
  productName String?
  storeName   String?
  imageUrl    String?
  price       Float?
  currency    String?

  // "public" | "private". Matches the frontend Wish.visibility convention.
  visibility String @default("public")

  // Deactivation cascade (when Product or Store deactivated).
  // Same vocabulary as the product availability rule (see
  // QIFT_PLATFORM_ARCHITECTURE Section 9.6).
  deactivatedAt     DateTime?
  deactivatedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Relation field is named `linkedProduct` / `linkedStore` to
  // avoid colliding with the legacy scalar `store: String?` field
  // (free-text storeName for pre-v2 wishes). The scalar wins the
  // name `store` for backwards compat; relations use the
  // `linked*` prefix.
  linkedProduct Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  linkedStore   Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)

  // One wishlist row per (userId, productId). Postgres treats NULL
  // as distinct, so multiple legacy free-text rows with productId =
  // null on the same user are still allowed.
  @@unique([userId, productId])
  @@index([userId])
  // Hot path: list a user's public wishes newest-first.
  @@index([userId, visibility, createdAt])
  // "N people want this" aggregate query.
  @@index([productId])
}

// Many-to-many social graph (added in Step 2). One row = "follower
// follows following". The composite primary key prevents duplicates
// without a separate unique constraint.
model Follow {
  followerId  String
  followingId String
  // "pending" | "accepted". Public users transition straight to "accepted".
  // Private users (User.profileVisibility = "private") may sit in
  // "pending" until they approve the request — the API decides which
  // value to store at follow-time.
  status      String    @default("accepted")
  createdAt   DateTime  @default(now())
  // Set when status transitions to "accepted". For instant-accept rows
  // it equals createdAt.
  acceptedAt  DateTime?

  follower  User @relation("OutgoingFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("IncomingFollows", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  // "Who follows me, newest first" — the followers-list query.
  @@index([followingId, createdAt])
  // "Who am I following, newest first" — the following-list query.
  @@index([followerId, createdAt])
}

// User-to-user block. Composite PK on (blockerId, blockedId) so
// duplicate blocks collapse to a no-op insert. Search + public-profile
// + send-gift gates filter on this table in BOTH directions: A blocked
// B means A doesn't see B's content AND B doesn't see A's content
// (mirrors how every modern social app handles blocks). Cascades clean
// up on user deletion.
model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  // Reverse-direction lookup — "who has blocked ME" — needed by the
  // search filter to exclude the blocker from the blocked user's view.
  @@index([blockedId])
}

// User report. Admin-only surface (no GET endpoint exposed to
// non-admin users). `reason` is a short discriminator from a
// frontend-defined allow-list; `details` is optional free text.
// `status` lifecycle: open → reviewed → (dismissed | actioned).
//
// We index by (status, createdAt) so an admin queue UI can fetch the
// open backlog efficiently. We also index by reportedUserId so a
// safety dashboard can count reports per user.
model Report {
  id             String   @id @default(cuid())
  reporterId     String
  reportedUserId String
  reason         String
  details        String?
  status         String   @default("open")
  createdAt      DateTime @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reportedUserId])
}

// DORMANT — legacy generic-posting model.
//
// The application code that consumed this model (PostsModule on the
// backend, lib/posts.ts + PostsViewer on the frontend) was retired
// in the dormant-generic-posting cleanup. Qift posts now originate
// from gifting events ONLY (see `project_gift_centric_social.md`
// + the GiftPost model below).
//
// The table is kept in the database for now so historical rows are
// not destroyed. A future migration will drop the table once the
// data is reviewed / archived. Until then:
//   - No service writes to this table.
//   - No service reads from this table.
//   - The relation field on User (`posts Post[]`) is retained for
//     schema integrity but is never queried.
//
// Do NOT add new consumers. If you find yourself needing a
// "user-uploaded media" surface, route it through GiftPost or
// surface a design discussion first — generic posting is an
// explicit non-direction for the platform.
model Post {
  id        String   @id @default(cuid())
  userId    String
  mediaUrl  String
  mediaType String
  caption   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ============================================================
// Phase 6 — Occasions infrastructure
// ============================================================
//
// Birthdays, anniversaries, religious events, milestones. Stored
// as relationship infrastructure, NOT as a content feed. Every
// downstream system that needs gifting-timing context — reminders,
// recommendations, AI gifting, discovery rails — reads from this
// model.
//
// Full architecture: project_occasions_architecture.md in user
// memory. Read that document before touching this schema.
//
// CRITICAL DECISIONS BAKED INTO THIS SHAPE:
//
//   1. (calendar, year?, month, day) triple, NOT a DateTime.
//      A Gregorian DateTime can't represent "every year on the
//      second of Shawwal" correctly — Hijri drifts ~11 days per
//      Gregorian year. The triple lets nextOccurrence() resolve
//      in either calendar; the Hijri ↔ Gregorian conversion goes
//      through lib/hijri.ts (single shared helper).
//
//   2. recurrence is 'once' | 'yearly' ONLY. Not 'monthly',
//      'weekly', or 'cron-style' — those don't map to gifting
//      reality and would open the door to spam patterns.
//
//   3. visibility is 'private' | 'followers' | 'mutual' | 'public'.
//      Defaults to 'private'. canSeeOccasion() in OccasionsService
//      is the SINGLE enforcement boundary; every read path routes
//      through it.
//
//   4. relatedUserId is OPTIONAL. Set when one user remembers
//      ANOTHER user's occasion ("Sarah's birthday" owned by me,
//      pointing at Sarah). The owner of the row is whoever wants
//      the reminder, not necessarily the person the occasion is
//      "about".
//
//   5. The reminder firing job is NOT BUILT IN PHASE 6.1. The
//      OccasionReminder model is created (so future Phase 7 work
//      has a populated data layer to switch on), but no cron, no
//      notification firing. Reminders default to digest channel
//      and `enabled: true`; the budget infrastructure in Phase 7
//      activates them.

model Occasion {
  id              String    @id @default(cuid())

  // -- Identity ---------------------------------------------------
  // Who owns this row. The owner is whoever wants the reminder
  // / sees it on their /occasions page. NULL is reserved for
  // future platform-defined cultural rows (Eid, Saudi National
  // Day) — V1 doesn't ship those seeds yet, but the column allows
  // them. User-created rows always have a userId.
  userId          String?
  // Discriminator. Validated server-side against the OCCASION_KINDS
  // allow-list in OccasionsService — unknown values are rejected
  // at the API boundary, not at the schema layer (the column stays
  // a free string so the allow-list can evolve without a migration).
  kind            String
  // Optional free-text title. Used for 'custom' kind ("Mom's 60th"),
  // for an extra label on a recurring birthday ("at the new place"),
  // or left null when the kind speaks for itself. Length-capped
  // server-side (80 chars).
  label           String?

  // -- Date (calendar-aware triple) ------------------------------
  calendar        String    // 'gregorian' | 'hijri'
  // Month + day are 1-indexed, in the chosen calendar. For one-off
  // dated occasions (graduation, wedding), the year is also set so
  // the row identifies a specific moment; for yearly recurring,
  // year is null.
  year            Int?
  month           Int       // 1-12
  day             Int       // 1-31 (per calendar)

  // -- Recurrence ------------------------------------------------
  recurrence      String    // 'once' | 'yearly'

  // -- Privacy ---------------------------------------------------
  // 'private' | 'followers' | 'mutual' | 'public'. Default
  // private. canSeeOccasion() is the single read-time enforcement
  // point; do NOT add bare prisma.occasion.find* outside
  // OccasionsService.
  visibility      String    @default("private")

  // -- Regional / cultural metadata -----------------------------
  // ISO 3166-1 alpha-2 (e.g. 'SA') or a region group ('GULF',
  // 'MENA') for shared cultural occasions. NULL for user-created
  // rows. Drives the UI's "show cultural occasions for my region"
  // toggle in a future iteration.
  regionCode      String?

  // -- Relationships --------------------------------------------
  // OPTIONAL link to a related user — "Sarah's birthday" sets
  // userId = me, relatedUserId = Sarah's user id. Drives the
  // reminder copy that names the person. NULL when the occasion
  // is about the owner themselves OR about a person not on Qift.
  relatedUserId   String?

  // -- Lifecycle ------------------------------------------------
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  // Soft-delete so reminder firing history + gift FKs survive. A
  // hard delete would orphan Gift.occasionId pointing at it (we
  // SetNull on that side); the deactivatedAt flag lets the
  // OccasionsService filter "active" rows without losing the
  // historical link.
  deactivatedAt   DateTime?

  // -- Relations ------------------------------------------------
  user            User?              @relation("OwnedOccasions", fields: [userId], references: [id], onDelete: Cascade)
  relatedUser     User?              @relation("RelatedOccasions", fields: [relatedUserId], references: [id], onDelete: SetNull)
  gifts           Gift[]             @relation("OccasionGifts")
  reminders       OccasionReminder[]

  // -- Indexes --------------------------------------------------
  // Owner's /occasions page list query.
  @@index([userId, deactivatedAt])
  // "Who remembers this person's birthday" — used when surfacing
  // mutual-follow occasions on /u/[username].
  @@index([relatedUserId, deactivatedAt])
  // Hot path for the future reminder sweep — find every occasion
  // firing today across all users. O(matched), not O(N).
  @@index([calendar, month, day, deactivatedAt])
}

// Per-user reminder for an occasion. The reminder OWNS the cadence
// + channel + enabled flag; the occasion itself is just the
// anchor date.
//
// One reminder row per (userId, occasionId, daysBefore). A user
// who wants both T-7 and T-1 has two rows.
//
// The reminder OWNER is the user receiving the reminder, not the
// occasion's owner — when a remembering user creates a reminder
// for someone else's occasion, the reminder's userId = the
// remembering user. This makes the reminder sweep a simple
// `WHERE userId = :viewerId AND enabled = true` per user.
//
// Phase 6.1 ships the data layer ONLY. Reminder FIRING is gated
// to Phase 7's notification budget infrastructure.
model OccasionReminder {
  id            String    @id @default(cuid())
  userId        String
  occasionId    String
  // Days before the occurrence. Default cadence (Section 7.2 of
  // the architecture doc) seeds T-7 and T-1 for personal recurring
  // kinds; user can override or disable per row.
  daysBefore    Int
  // 'digest' | 'real_time'. Default 'digest' — the architecture
  // memory's notification discipline (Section 17 of the canonical
  // doc) puts low-priority reminders in the daily digest, with
  // opt-in real-time only for high-priority life-milestone rows.
  channel       String    @default("digest")
  // Soft-disable so the user can mute one reminder without
  // deleting the whole row (preserves the daysBefore choice for
  // re-enabling).
  enabled       Boolean   @default(true)

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  occasion      Occasion  @relation(fields: [occasionId], references: [id], onDelete: Cascade)
  // Phase 7.2 — firing audit log. One row per (reminder,
  // occurrenceDate) so a yearly birthday produces ONE
  // ReminderFiring per year. The composite unique constraint
  // there is what enforces "fire each reminder once per
  // occurrence" idempotency.
  firings       ReminderFiring[]

  // One reminder per (user, occasion, daysBefore) — re-creating
  // the same shape is an idempotent no-op via upsert.
  @@unique([userId, occasionId, daysBefore])
  // Per-user enabled-reminder query for the future sweep.
  @@index([userId, enabled])
}

// Phase 7.2 — occasion-reminder firing audit table.
//
// Append-only log of every reminder firing attempt. The unique
// constraint on (reminderId, occurrenceAt) is the load-bearing
// idempotency guarantee:
//
//   - "occurrenceAt" is the UTC midnight of the day the parent
//     occasion fires (NOT the day the reminder dispatches). A
//     yearly birthday on May 15 produces:
//       occurrenceAt = 2026-05-15  → one ReminderFiring per
//                                     reminder that year
//       occurrenceAt = 2027-05-15  → a fresh row next year
//   - Re-running the worker for the same (reminderId,
//     occurrenceAt) hits the unique constraint and is a no-op.
//   - The worker INSERTS this row BEFORE calling the orchestrator.
//     If the orchestrator write fails, the row stays as a "claim"
//     with status='claimed', preventing duplicate retry. A
//     follow-up audit pass can clean stale claims; see Section 8
//     of the worker doc-comment for the operational story.
//
// status values:
//   claimed    — row inserted, orchestrator call pending
//   sent       — orchestrator wrote a Notification + (maybe) push
//   suppressed — orchestrator decided not to send (opt-out / budget)
//   failed     — orchestrator threw an unexpected error
//
// reason: copied verbatim from the orchestrator's EnqueueResult
//   when status is 'suppressed' / 'failed'. Telemetry-friendly.
model ReminderFiring {
  id           String   @id @default(cuid())
  reminderId   String
  // UTC-midnight Date of the occasion's occurrence this firing
  // covers. Computed by the worker from the parent occasion's
  // recurrence + the reminder's daysBefore.
  occurrenceAt DateTime
  firedAt      DateTime @default(now())
  // 'claimed' | 'sent' | 'suppressed' | 'failed'
  status       String   @default("claimed")
  // Free-form telemetry. 'daily_cap_exceeded', 'user_opted_out',
  // 'quiet_hours', etc. — mirrors orchestrator EnqueueResult.
  reason       String?

  reminder OccasionReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  // The idempotency anchor. Two workers racing on the same
  // (reminder, occurrence) collide here — exactly one wins.
  @@unique([reminderId, occurrenceAt])
  // Operator queries: "show me every firing for today" / "what's
  // pending follow-up". One index covers both.
  @@index([occurrenceAt, status])
}

// Invitation MVP — manual-share. A sender hits a "no match" state
// in /search (phone/email/social handle that isn't on Qift yet)
// and asks Qift to mint an invite link they can copy + share
// MANUALLY via the recipient's preferred channel. There is NO
// automated SMS/email/social DM send here — the provider seam
// exists (InviteProvider) but the only implementation today is
// ManualShareProvider, which just generates the URL + the calm
// suggested-message string the sender copies.
//
// PRIVACY DESIGN (load-bearing)
//
//   1. The Invite row does NOT store the raw channel value (phone
//      number / email / social handle). Only the coarse channel
//      type ('phone' | 'email' | 'social' | 'unknown') + optional
//      platform discriminator for social. This makes invite-table
//      reads useless for enumeration attacks.
//
//   2. The token is an opaque, sufficiently-random string
//      (24+ bytes, base64url). No id-incrementing, no
//      predictability. Public token resolution
//      (GET /invites/by-token/:token) returns the MINIMUM payload
//      that lets the public landing page decide what to render.
//
//   3. Token resolution NEVER reveals whether a given channel
//      value exists on Qift. The sender-side flow doesn't even
//      consult the invite table for "is this user on Qift?" —
//      that's the search endpoint's job, and search already
//      respects per-user discoverability flags.
//
// LIFECYCLE
//
//   active     — created and within expiresAt. The sender can
//                share the link; the recipient can land on /i/<token>
//                and register.
//   expired    — past expiresAt. Lazy transition (no cron); the
//                resolver checks `now < expiresAt` at read time.
//   revoked    — sender explicitly cancelled the link via
//                POST /invites/:id/revoke. Public resolver returns
//                isValid=false.
//   consumed   — a registered user landed on /i/<token> and joined
//                via that link. Single-use by default.
//
// RATE LIMITS
//   Per-sender daily cap on Invite.create. Read with a single
//   COUNT(*) on (createdByUserId, createdAt >= 24h ago). No new
//   table for rate-limit counters — Invite is its own audit log.
model Invite {
  id              String   @id @default(cuid())
  // Opaque token used in the public URL (/i/<token>). Random
  // bytes base64url-encoded. UNIQUE so resolution is O(1) and
  // collisions are vanishingly improbable. The token IS the
  // capability — possession is the only credential the recipient
  // needs to land on the public page.
  token           String   @unique
  // The sender (always set). Required for audit + rate-limit
  // + revocation ownership checks.
  createdByUserId String
  // Coarse channel discriminator. NEVER the raw value.
  //   'phone'   — sender typed a phone number we don't know yet
  //   'email'   — sender typed an email we don't know yet
  //   'social'  — sender typed a social handle (see `platform`)
  //   'unknown' — sender wants a general invite link, no channel
  channel         String
  // For channel='social' only. One of the SocialPlatform values
  // from the frontend (snapchat, tiktok, instagram, x, facebook,
  // youtube, threads, telegram). Null for non-social channels.
  // Drives the "Open Snapchat" / "Open TikTok" frontend hint.
  platform        String?
  // Lifecycle. See doc-comment above for transitions.
  //   active | expired | revoked | consumed
  status          String   @default("active")
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  // Set when the invite is consumed (recipient registered via
  // the public landing page). Null otherwise.
  consumedByUserId String?
  consumedAt      DateTime?

  createdBy   User  @relation("InviteCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  consumedBy  User? @relation("InviteConsumer", fields: [consumedByUserId], references: [id], onDelete: SetNull)

  // Per-sender history queries + rate-limit count(*) reads. The
  // combination (userId, createdAt) is the natural index for
  // "show this sender their invites" + "how many did this sender
  // mint in the last 24h".
  @@index([createdByUserId, createdAt])
}

// ───────────────────────────────────────────────────────────────────
// CLOSED BETA GATE
//
// These three models back the closed-beta registration gate. They are
// DELIBERATELY NAMED `Beta*` to avoid collision with the gift `Invite`
// model above — that one is the recipient-facing "join Qift to receive
// your gift" link; THESE govern *who may register at all* while the
// platform is in closed beta.
//
// The gate is master-switched by the BETA_GATE_ENABLED env var (off in
// code, on in production). When OFF, none of these tables are consulted
// — registration is fully open. When ON, /auth/register admits a new
// account ONLY if one of:
//   1. the email / email-domain / phone is on the allowlist, OR
//   2. a valid (non-disabled, non-expired, non-exhausted) BetaInviteCode
//      is supplied, OR
//   3. the requester is bypassing via super_admin (handled at a higher
//      layer, not here).
//
// EXISTING ACCOUNTS ARE NEVER AFFECTED: the gate runs only on the
// *new-user* branch of register(), after the existing-user login
// early-return. A returning user logs in regardless of gate state.
//
// `createdBy` / `userId` are plain String columns (user ids), NOT Prisma
// relations, on purpose: the gate is an operational side-table that
// should not add inbound relation fields to the already-large User
// model, and an admin who is later purged should not cascade-delete the
// audit of which codes they minted.
// ───────────────────────────────────────────────────────────────────

// A redeemable closed-beta invite code. `usedCount` is incremented
// atomically inside the same transaction as the user.create it admits,
// guarded by a conditional updateMany (usedCount < maxUses) so two
// concurrent redemptions of the last slot cannot both succeed.
model BetaInviteCode {
  id          String    @id @default(cuid())
  // The redeemable code. Stored normalised (trimmed, uppercased) so
  // lookup is exact and case-insensitive at the application layer.
  code        String    @unique
  // Operator-facing free-text label ("Q1 press list", "Founder
  // friends"). Never shown to the registrant.
  label       String?
  // Null = unlimited uses. Otherwise the hard cap; redemption is
  // refused once usedCount reaches this value.
  maxUses     Int?
  usedCount   Int       @default(0)
  // Null = never expires. Otherwise the code is invalid once now()
  // passes this instant (checked at decision time AND defensively in
  // the redemption WHERE).
  expiresAt   DateTime?
  // Set when an operator disables the code. A disabled code is
  // invalid regardless of remaining uses / expiry. Soft-disable
  // (not delete) preserves the redemption audit trail.
  disabledAt  DateTime?
  // User id of the operator who minted the code (audit).
  createdBy   String
  createdAt   DateTime  @default(now())

  redemptions BetaInviteRedemption[]

  // "list active codes" filters on disabledAt; "find by code" uses
  // the unique index above.
  @@index([disabledAt])
}

// One row per (code, user) successful redemption. The @@unique guard
// makes redemption idempotent — a retried register cannot double-count
// the same user against a code.
model BetaInviteRedemption {
  id         String         @id @default(cuid())
  codeId     String
  code       BetaInviteCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  // The user admitted by this redemption. Plain String (not a
  // relation) for the same reason as BetaInviteCode.createdBy.
  userId     String
  redeemedAt DateTime       @default(now())

  @@unique([codeId, userId])
  @@index([codeId])
}

// An allowlist entry. `kind` discriminates the match strategy:
//   'email'        — exact lowercased email match
//   'email_domain' — match any email whose domain equals `value`
//   'phone'        — exact normalised E.164 phone match
// `value` is always pre-normalised by the admin endpoint before insert
// (lowercased email/domain; E.164 phone), so the registration-time
// lookup is a plain equality probe with no per-row transformation.
model BetaAllowlistEntry {
  id        String   @id @default(cuid())
  kind      String   // 'email' | 'email_domain' | 'phone'
  value     String   // normalised match value
  label     String?
  createdBy String
  createdAt DateTime @default(now())

  // One entry per (kind, value); the same index serves the
  // registration-time equality lookup.
  @@unique([kind, value])
  @@index([kind, value])
}

// Persistent audit trail (PR 5 foundation — platform stabilization).
//
// One row per security-relevant action. The shape deliberately
// matches AdminService.recordAuditTODO's input so the deferred
// admin call-sites can swap onto AuditService.record mechanically
// (PR 7). First writer: the self-serve change-phone flow.
//
// `actorUserId` / `targetId` are plain TEXT (no FK to User) on
// purpose — an audit row must survive the purge of the actor or
// the target; trails that vanish with the account are not trails.
// PII policy: metadata MAY carry old/new contact values for
// support forensics (account-takeover disputes need the previous
// value). The table is admin-read-only; nothing here is ever
// returned on a public endpoint.
model AuditLog {
  id          String   @id @default(cuid())
  // Nullable to match production reality: the table predated the
  // migration history (created by the week2-era audit experiment)
  // and carries legacy rows with NULL actors. New writers ALWAYS
  // set it — AuditService.record requires actorUserId — but a
  // reader (the PR 11 viewer) must be able to deserialise the
  // legacy rows. See migration 20260611000000_audit_log_align.
  actorUserId String?
  actorType   String // 'admin' | 'user' | 'system'
  action      String // dot-namespaced, e.g. 'user.phone.change'
  targetType  String // 'user' | 'store' | 'system'
  targetId    String?
  metadata    Json?
  // Legacy week2-era columns that exist on the production table.
  // Unused by current writers; modelled so introspection/diff stays
  // clean and a future risk layer can re-adopt them.
  ipHash        String?
  userAgentHash String?
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
}

// ── Financial ledger substrate (PR 2 — dark-launched) ───────────────
//
// Append-only record of money-relevant events. This is the FOUNDATION
// future invoice / settlement / reconciliation work will read from —
// NOT a full accounting system, and NOTHING writes to it in this PR
// (dark launch: the table + service ship, no producer is wired).
//
// Append-only is enforced two ways: by convention here, and by the
// service API — FinancialLedgerService exposes only record() + read
// helpers; there is deliberately no update/delete path anywhere.
//
// PURGE SURVIVABILITY: every correlation id (orderId, paymentId,
// storeId, orgId, campaignId, actorId) is plain TEXT with NO foreign
// key — the same philosophy as AuditLog / DispatchJob / ClaimableGift.
// A financial trail must outlive the purge of the actor or entity it
// references (regulatory retention — ZATCA financial records).
//
// MONEY TYPE: `amount` is Float to match the existing Order / Payment
// money columns, so reconciliation needs no cross-type conversion. It
// is a positive magnitude; `direction` carries the debit/credit sense
// so the substrate is double-entry-ready.
model FinancialLedgerEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // What happened. `eventType` = high-level category (e.g.
  // 'order.captured', 'payout.accrued'); `reasonCode` = specific
  // machine code (e.g. 'ORDER_CAPTURE', 'QIFT_SERVICE_FEE').
  eventType  String
  reasonCode String

  // Who caused it. 'system' for automated postings. Plain-TEXT actorId
  // (purge-survivable), nullable for system events.
  actorType String
  actorId   String?

  // Money. Positive magnitude + explicit direction.
  amount    Float
  currency  String
  direction String // 'credit' | 'debit'

  // The other side of the entry, when meaningful (e.g. 'merchant',
  // 'qift', 'sender', 'psp'). Qift's merchant IS the store, so there is
  // no separate merchantId — storeId identifies the merchant side.
  counterpartyType String?

  // Correlation ids — all plain TEXT, all nullable, NO FK (survivability).
  orderId    String?
  paymentId  String?
  campaignId String?
  orgId      String?
  storeId    String?

  // Free-form context. MUST NOT carry recipient address / location /
  // phone data — FinancialLedgerService strips known-sensitive keys
  // before persisting.
  metadata Json?

  @@index([orderId])
  @@index([paymentId])
  @@index([campaignId])
  @@index([orgId])
  @@index([storeId])
  @@index([reasonCode, createdAt])
  @@index([eventType, createdAt])

  // Idempotency (PR 3). One entry per (order, reasonCode): a paid order
  // posts each reasonCode (ORDER_PAID, QIFT_SERVICE_FEE, …) at most
  // once, so a retried payment confirmation cannot duplicate ledger
  // rows — the second write hits P2002 and is treated as already-posted.
  // Relies on PostgreSQL NULL-distinct semantics: non-order entries
  // (orderId = NULL) are never constrained, matching the Gift /
  // DispatchJob idempotency-key pattern already used in this schema.
  @@unique([orderId, reasonCode])
}

// ── Corporate Invoice (PR 4 — the first corporate money entity) ─────
//
// Issued when a GiftCampaign is APPROVED (the SoD-locked commercial
// commitment point). Amounts are frozen from the campaign's approval
// snapshot: company owes Qift `totalAmount` = subtotal (gift value) +
// platform fee. Manual / offline settlement only in the pilot — no live
// PSP, no ZATCA XML, no merchant settlement here.
//
// SURVIVABILITY: orgId and campaignId are plain TEXT with NO foreign key
// — a financial record must outlive the purge of the org or campaign it
// bills (regulatory retention), matching the AuditLog / FinancialLedger
// posture. `@@unique([campaignId])` is the idempotency anchor: exactly
// one invoice per campaign, so repeated approval/dispatch cannot
// duplicate it.
//
// PRIVACY: no employee identity, address, phone, or claim choice is ever
// stored here. metadata carries only non-PII line context (product /
// store name + fee-policy version).
model CorporateInvoice {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orgId      String // plain TEXT, no FK (purge-survivable)
  campaignId String // plain TEXT, no FK (purge-survivable)

  // draft | issued | cancelled | paid | void. Created as 'issued' at
  // approval; the 'paid' transition (offline settlement) + its ledger
  // allocation land in PR 5.
  status String @default("issued")

  currency          String @default("SAR")
  recipientCount    Int
  unitAmount        Float // frozen gift price from the approval snapshot
  subtotalAmount    Float // unitAmount * recipientCount
  platformFeeAmount Float // Qift fee (FeeEngine rate) * recipientCount
  totalAmount       Float // subtotalAmount + platformFeeAmount

  dueDate     DateTime?
  issuedAt    DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?

  metadata Json?

  @@unique([campaignId])
  @@index([orgId])
  @@index([status, createdAt])
  @@index([issuedAt])
}

// ── Corporate Foundation (approved scope, PR 1) ─────────────────────
//
// Organization — the corporate customer (Corporate Core v2 §2.1).
// Review lifecycle mirrors Store (draft → submitted → approved /
// rejected / changes_requested / suspended). `createdBy` /
// `reviewedBy` are plain TEXT user ids (no FK) per the established
// audit-table posture: org records must survive a user purge.
model Organization {
  id            String    @id @default(cuid())
  legalName     String
  displayName   String
  displayNameAr String?
  crNumber      String?
  vatNumber     String?
  billingEmail  String?
  billingAddress String?
  status        String    @default("draft")
  riskTier      String    @default("new") // 'new' | 'established' | 'strategic'
  rejectionReason String?
  // Bounded org settings (wave caps, retention days). JSONB so
  // additive keys never need a migration; writers sanitize.
  settings      Json?
  createdBy     String
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewedBy    String?
  createdAt     DateTime  @default(now())

  seats     OrgUser[]
  contacts  CorporateContact[]
  campaigns GiftCampaign[]

  @@index([status])
}

// OrgUser — console seats for the 2–5 humans who RUN campaigns.
// Deliberately NOT the roster: employees never appear here.
// `userId` is plain TEXT (no FK) for purge-survivability; the
// OrgRoleGuard joins it against live Users at request time, so a
// purged user's seat is inert even before it's revoked.
model OrgUser {
  id        String    @id @default(cuid())
  orgId     String
  userId    String
  role      String // 'owner' | 'admin' | 'approver' | 'viewer'
  invitedBy String?
  acceptedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

// CorporateContact — the company's gift ROSTER (Corporate
// Foundation PR 2; Corporate Core v2 §3). One row per person the
// company may gift to. Three structural rules:
//
//   1. NO FK to User — EVER. Whether a roster person is also a Qift
//      consumer is unrepresentable here; employment data and
//      consumer identity never join (Corporate Core v2 §3.2).
//   2. NO address fields. Delivery addresses are collected from the
//      RECIPIENT at claim time (ClaimAddress, PR 5); the company
//      never supplies them and the import gate rejects CSVs that
//      try (address-column rejection).
//   3. Retention-bounded: every row carries purgeAfter; the purge
//      worker hard-deletes expired rows. Roster data is borrowed,
//      not owned.
model CorporateContact {
  id            String    @id @default(cuid())
  orgId         String
  fullName      String
  email         String?   // lowercased at import
  phone         String?   // E.164 (normalizePhone) at import
  department    String?
  employeeRef   String?   // company's own opaque reference
  status        String    @default("active") // 'active' | 'archived'
  importBatchId String?
  purgeAfter    DateTime
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaignRecipients CampaignRecipient[]

  @@index([orgId, status])
  @@index([orgId, email])
  @@index([orgId, phone])
  @@index([purgeAfter])
}

// GiftCampaign — one corporate gifting wave (Corporate Foundation
// PR 3; Corporate Core v2 §4). Lifecycle:
//
//   draft → pending_approval → approved → dispatching → completed
//     ↑            |                          (PR 4)     (PR 4)
//     └── changes_requested ←┘
//   any non-terminal state → cancelled
//
// Maker–checker: the campaign's creator can NEVER approve it, even
// an owner (separation of duties is enforced in CampaignService on
// top of the approver/owner route guard).
//
// createdBy / approvedBy / cancelledBy are plain-TEXT user ids (no
// FK) — same purge-survivability posture as Organization.
model GiftCampaign {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  occasion    String?   // free-text label ('Eid', 'Founding Day', ...)
  message     String?   // greeting shown to recipients at claim time
  status      String    @default("draft")
  createdBy   String
  submittedAt DateTime?
  approvedBy  String?
  approvedAt  DateTime?
  reviewNote  String?   // approver's note on request_changes
  cancelledBy String?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org        Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  options    CampaignGiftOption[]
  recipients CampaignRecipient[]
  jobs       DispatchJob[]
  claims     ClaimableGift[]

  @@index([orgId, status])
}

// CampaignGiftOption — the gift a campaign sends. MVP is ONE option
// per campaign (one-gift-for-all; choice-of-K is modelled but NOT
// approved scope — the service enforces a single option).
//
// `approvalSnapshot` is the snapshot-at-approval: a frozen copy of
// the product + store identity taken the moment the campaign is
// approved. Product edits, price changes, or delistings after
// approval never alter what the org signed off on. Shape:
//   { productId, productName, price, imageUrl, category,
//     storeId, storeName }
model CampaignGiftOption {
  id               String    @id @default(cuid())
  campaignId       String
  productId        String    // live reference while drafting
  approvalSnapshot Json?
  snapshotAt       DateTime?
  createdAt        DateTime  @default(now())

  campaign GiftCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// CampaignRecipient — roster contacts selected for a campaign.
// FK CASCADE from CorporateContact: when a contact is purged or
// hard-deleted, its recipient rows vanish with it (draft campaigns
// simply shrink; active campaigns are protected because the purge
// worker skips contacts attached to pending_approval / approved /
// dispatching campaigns).
model CampaignRecipient {
  id         String   @id @default(cuid())
  campaignId String
  contactId  String
  createdAt  DateTime @default(now())

  campaign GiftCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  CorporateContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([contactId])
}

// DispatchJob — one unit of "get this recipient their claimable
// gift" (Corporate Foundation PR 4; Corporate Core v2 §5).
//
//   pending → processing → dispatched
//                │   └→ pending (retry while attempts < max)
//                └→ failed (permanent / attempts exhausted)
//   cancelled — reserved for ops intervention (unused by the MVP
//               worker; dispatching campaigns are not cancellable).
//
// idempotencyKey = campaignId:contactId — a recipient can never
// receive two jobs for the same wave, no matter how many times
// dispatch is retried or replayed.
//
// contactId is a plain TEXT id (NO FK): jobs are the dispatch
// LEDGER and must survive contact purges. The row itself carries no
// PII — channel values are read live from CorporateContact at
// processing time and never copied here.
//
// claimRef is the PR 5 seam: the ClaimableGift id once the claim
// flow mints one during processing. Null until then.
model DispatchJob {
  id             String    @id @default(cuid())
  campaignId     String
  contactId      String
  idempotencyKey String    @unique
  status         String    @default("pending")
  attempts       Int       @default(0)
  lastError      String?
  claimRef       String?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaign GiftCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([campaignId, status])
}

// ClaimableGift — the account-less claim record (Corporate
// Foundation PR 5; Corporate Core v2 §6). The recipient NEVER
// registers: token possession + OTP to the bound channel is the
// whole identity.
//
//   pending → claimed   (address confirmed — IRREVOCABLE)
//          → declined   (recipient said no)
//          → mismatch   ("this isn't me" after the identity echo)
//          → expired    (claim window lapsed; lazily marked)
//          → revoked    (reserved for ops intervention)
//
// PRIVACY STRUCTURE:
//   * tokenHash only — the raw claim token never persists.
//   * The pre-OTP surface (teaser) exposes NOTHING identifying: no
//     name, no org, no gift (F1 rule — pinned by tests).
//   * recipientName / channelValue / orgDisplayName / giftSnapshot
//     are SNAPSHOTS taken at mint so the claim survives roster
//     purges; they are revealed ONLY after OTP verification.
//   * contactId is plain TEXT (no FK) — linkage for counters, dead
//     after purge by design.
model ClaimableGift {
  id               String    @id @default(cuid())
  campaignId       String
  contactId        String
  jobId            String?   @unique
  tokenHash        String    @unique
  status           String    @default("pending")
  recipientName    String
  channel          String // 'phone' | 'email'
  channelValue     String
  orgDisplayName   String
  campaignMessage  String?
  giftSnapshot     Json
  sessionTokenHash String?
  sessionExpiresAt DateTime?
  otpVerifiedAt    DateTime?
  claimedAt        DateTime?
  declinedAt       DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  campaign GiftCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  address  ClaimAddress?

  @@index([campaignId, status])
}

// ClaimAddress — where the recipient wants their gift delivered.
// STRUCTURALLY separate from the consumer Address table AND from
// everything the org can read: NO API endpoint returns this row to
// anyone (Corporate Core v2 §6: the company never sees employee
// addresses; fulfillment is ops-manual in the pilot). Write-only
// from the claim flow.
model ClaimAddress {
  id        String   @id @default(cuid())
  claimId   String   @unique
  fullName  String?
  phone     String
  country   String
  region    String?
  city      String
  district  String?
  line1     String
  notes     String?
  createdAt DateTime @default(now())

  claim ClaimableGift @relation(fields: [claimId], references: [id], onDelete: Cascade)
}

// StoreBusinessProfile — Qift Business eligibility (B1; Business
// Marketplace review §3).
//
//   (no row) → applied → approved / rejected
//   approved → suspended → approved (reinstate)
//   rejected → applied (re-application updates the same row)
//
// INDEPENDENCE INVARIANT: consumer approval NEVER implies business
// approval. A store sells to companies only when BOTH its consumer
// status is 'approved' AND this profile is 'approved' — the
// isBusinessEligible() helper in StoreBusinessService is the single
// seam future supply features (BusinessListing, B2+) must consult.
//
// appliedBy / reviewedBy are plain-TEXT user ids (purge
// survivability — same posture as Organization / GiftCampaign).
model StoreBusinessProfile {
  id         String    @id @default(cuid())
  storeId    String    @unique
  status     String    @default("applied") // applied | approved | rejected | suspended
  appliedBy  String?
  appliedAt  DateTime  @default(now())
  reviewedAt DateTime?
  reviewedBy String?
  reason     String? // rejection / suspension reason, shown to the merchant
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([status])
}
