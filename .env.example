# Qift API — environment template.
#
# Copy to `.env` for local dev, or wire each value into your PaaS
# (Railway / Render / Fly / Heroku) project secrets for production.
#
# Required for the app to boot in any environment:
#   - DATABASE_URL
#
# Required for production specifically (see DEPLOYMENT.md):
#   - JWT_SECRET     — long random string
#   - CORS_ORIGINS   — comma-separated list of frontend origins
#   - PORT           — usually injected by the PaaS; default 4000
#
# Optional (features degrade gracefully when missing):
#   - VAPID_*        — push notifications
#   - TAQNYAT_*      — SMS OTP delivery
#   - STORE_USER_IDS — admin override for store-dashboard access

# ── Database ──────────────────────────────────────────────────────────
# Local dev (default): SQLite file relative to prisma/schema.prisma.
DATABASE_URL="file:./dev.db"
# Production: a hosted Postgres URL. Switch `provider` in
# prisma/schema.prisma from "sqlite" to "postgresql" when you move to
# Postgres. See DEPLOYMENT.md "Postgres migration" for the safe path.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/qift?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────
# JWT signing secret. Local dev falls back to a hardcoded literal so a
# fresh checkout boots without configuration; PRODUCTION MUST SET THIS
# to a long random string. Rotating it invalidates every issued token.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# JWT_SECRET=

# ── HTTP ──────────────────────────────────────────────────────────────
# PORT is usually injected by the PaaS. Local default: 4000.
# PORT=4000
# CORS allow-list — comma-separated frontend origins.
# The production domains (https://qift.net, https://www.qift.net)
# are baked into the code-level allow-list in src/main.ts so they
# work even if this env var is unset. Localhost:* and the matching
# Vercel project URLs are also always allowed.
# Use CORS_ORIGINS to add staging / preview / alternate domains.
# CORS_ORIGINS=https://staging.qift.net

# ── Push notifications (optional, fails gracefully when missing) ──────
# Generate keys with:  npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@qift.net

# ── SMS OTP (optional, falls back to console-log delivery) ────────────
# TAQNYAT_BEARER_TOKEN=
# TAQNYAT_SENDER=Qift

# ── Transactional email (Resend) ──────────────────────────────────────
# All four are read by MailService (src/mail/mail.service.ts). The API
# key is REQUIRED for real delivery — without it, every email send
# no-ops with a warn log and the rest of the app keeps working
# (mirrors the push / SMS service patterns).
#
# Mailbox roles (Google Workspace handles the inboxes; Resend handles
# the outbound transactional sends — they coexist on qift.net via DNS):
#   noreply@qift.net   — generic from for welcome / password reset / gift
#   otp@qift.net       — dedicated from for verification codes
#   support@qift.net   — surfaced in every email's footer + as the
#                         support contact for inbound replies
#   merchants@qift.net — from address for merchant alerts (the bucket
#                         operators triage merchant tickets out of)
#
# DKIM / SPF / DMARC must already be set up on qift.net via the Resend
# console. Don't change the domain here without re-verifying those.
# RESEND_API_KEY=
# EMAIL_FROM=noreply@qift.net
# OTP_EMAIL_FROM=otp@qift.net
# SUPPORT_EMAIL=support@qift.net

# ── Admin escape hatch (optional) ─────────────────────────────────────
# Comma-separated user IDs that get unscoped store-dashboard access.
# STORE_USER_IDS=

# ── Closed-beta sandbox simulation mode ───────────────────────────────
# When set to the literal string "true", every Order and Gift created
# by this deploy is forced isSandbox=true server-side, regardless of
# what the request body sends. Sandbox orders walk the full
# lifecycle (address-confirm, merchant accept/prepare/ship/deliver,
# notifications, recipient confirmation) but capture no real money
# and produce no settling PayoutEvents.
#
# Default behaviour when this env var is UNSET, EMPTY, or any value
# other than the exact string "true" is LIVE mode. Production deploys
# must NOT set this. Closed-beta / staging deploys SHOULD set this
# explicitly to true so a forgotten flag in the frontend cannot
# create live orders.
#
# Resolution lives in src/payments/sandbox-mode.ts (single source of
# truth). Once a row is written its isSandbox column is the authority
# for the rest of its lifecycle; flipping this env var mid-flight
# only affects new rows.
# SANDBOX_ONLY_MODE=true

# ── Media storage (Cloudflare R2 via S3-compatible API) ───────────────
# All five vars are required to enable media uploads. With any of them
# missing, POST /media/* returns 503 (the rest of the API still boots
# normally — media is the only thing that depends on them).
#
# R2_ACCOUNT_ID — your Cloudflare account ID. Used to compute the
#   default endpoint when R2_ENDPOINT isn't explicitly set.
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY — credentials from a
#   Cloudflare R2 API token scoped Object Read & Write to R2_BUCKET.
# R2_BUCKET — the bucket name (e.g. `qift-media`).
# R2_ENDPOINT — full S3 endpoint. Optional; defaults to
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com when omitted.
#
# R2_PUBLIC_BASE_URL — REQUIRED. The public origin where uploaded
#   objects are served. Two options:
#     a) Recommended: a custom domain mapped to the bucket
#        (e.g. https://media.qift.net).
#     b) The R2-managed `pub-<id>.r2.dev` domain you get when you
#        flip on "Public access" for the bucket.
#   Without this, the API refuses to upload — we will not silently
#   store objects nobody can fetch. Keep the bucket otherwise
#   private; only the public domain should serve reads.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=qift-media
# R2_ENDPOINT=
# R2_PUBLIC_BASE_URL=
